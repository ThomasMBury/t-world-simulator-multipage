tauTransition2 = 1.0967 [ms] + (1 - sigmoidTransition2) * 141.4299 [ms]
    in [ms]
td = 1.5 [ms] + 1 [ms] / (exp(-0.05 [1/mV] * (membrane.v + 6 [mV])) + exp(0.09 [1/mV] * (membrane.v + 14 [mV])))
    in [ms]
tfcaf = 13.50673 [ms] + 1 [ms] / (0.1542 * exp(-(membrane.v - 1.31611 [mV]) / 11.3396 [mV]) + 0.1542 * exp((membrane.v - 1.31611 [mV]) / 11.3396 [mV]))
    in [ms]
tfcafp = 2.5 * tfcaf
    in [ms]
tfcas = 177.95813 [ms] + 1 [ms] / ( 4.73955000000000025e-4 * exp(-(membrane.v - 0.79049 [mV]) / 0.81777 [mV]) +  4.73955000000000025e-4 * exp((membrane.v + 2.40474 [mV]) / 1.90812 [mV]))
