VsTs_Ca_sl = P_tau_0 + (P_tau_max - P_tau_0) / (1 + (0.00015 [mM] / intracellular_ions.casl)^3)
    in [mV]
VsXs_Ca_junc = P_vh_0 + (P_vh_max - P_vh_0) / (1 + (0.00035 [mM] / intracellular_ions.caj)^4)
    in [mV]
VsXs_Ca_sl = P_vh_0 + (P_vh_max - P_vh_0) / (1 + (0.00035 [mM] / intracellular_ions.casl)^4)
    in [mV]
celltype_factor = piecewise(environment.celltype == 2, 0.5, 1)
    in [1]
gKs_factor = 0.01
    in [1]
gks_junc = P_g_0 + (P_g_max - P_g_0) / (1 + (0.00015 [mM] / intracellular_ions.caj)^1.3)
    in [1]
gks_sl = P_g_0 + (P_g_max - P_g_0) / (1 + (0.00015 [mM] / intracellular_ions.casl)^1.3)
    in [1]
kPKA_IKs = PKA.fIKs_PKA
    in [1]
sex_factor = piecewise(environment.sex == 1, 1.09, environment.sex == 2, 0.905, 1)
    in [1]
tauxs_junc = 2 * (50 [ms] + (50 [ms] + 350 [ms] * exp(-(membrane.v + 30 [mV])^2 / 4000 [mV^2])) / (1 + exp(-(membrane.v + VsTs_Ca_junc) / 10 [mV])))
    in [ms]
tauxs_sl = 2 * (50 [ms] + (50 [ms] + 350 [ms] * exp(-(membrane.v + 30 [mV])^2 / 4000 [mV^2])) / (1 + exp(-(membrane.v + VsTs_Ca_sl) / 10 [mV])))
    in [ms]
dot(xs_junc) = (xsss_junc - xs_junc) / tauxs_junc
