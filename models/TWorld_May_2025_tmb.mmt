x2_i = k1_i * k7_i * (k4_i + k5_i) + k4_i * k6_i * (k1_i + k8_i)
    in [1]
x2_ss = k1_ss * k7_ss * (k4_ss + k5_ss) + k4_ss * k6_ss * (k1_ss + k8_ss)
    in [1]
x3_i = k1_i * k3_i * (k7_i + k6_i) + k8_i * k6_i * (k2_i + k3_i)
    in [1]
x3_ss = k1_ss * k3_ss * (k7_ss + k6_ss) + k8_ss * k6_ss * (k2_ss + k3_ss)
    in [1]
x4_i = k2_i * k8_i * (k4_i + k5_i) + k3_i * k5_i * (k1_i + k8_i)
    in [1]
x4_ss = k2_ss * k8_ss * (k4_ss + k5_ss) + k3_ss * k5_ss * (k1_ss + k8_ss)
    in [1]

[INaK]
INaK = INaKj + INaKsl
    in [A/F]
INaK_junc_PKA = membrane.Fjunc * IbarNaK * fnak / (1 + (KmNaip_PKA / intracellular_ions.naj)^4) * extracellular.ko / (extracellular.ko + KmKo)
    in [A/F]
INaK_junc_noPKA = membrane.Fjunc * IbarNaK * fnak / (1 + (KmNaip / intracellular_ions.naj)^4) * extracellular.ko / (extracellular.ko + KmKo)
    in [A/F]
INaK_sl_PKA = membrane.Fsl * IbarNaK * fnak / (1 + (KmNaip_PKA / intracellular_ions.nasl)^4) * extracellular.ko / (extracellular.ko + KmKo)
    in [A/F]
INaK_sl_noPKA = membrane.Fsl * IbarNaK * fnak / (1 + (KmNaip / intracellular_ions.nasl)^4) * extracellular.ko / (extracellular.ko + KmKo)
    in [A/F]
INaKj = (1 - PKA.fINaK_PKA) * INaK_junc_noPKA + PKA.fINaK_PKA * INaK_junc_PKA
    in [A/F]
INaKsl = (1 - PKA.fINaK_PKA) * INaK_sl_noPKA + PKA.fINaK_PKA * INaK_sl_PKA
    in [A/F]
IbarNaK = multipliers.INaK_multiplier * IbarNaK_b
    in [A/F]
IbarNaK_b = 2.10774 [A/F]
    in [A/F]
KmKo = 1.5 [mM]
    in [mM]
KmNaip = 11 [mM]
    in [mM]
KmNaip_PKA = 8.4615 [mM]
    in [mM]
fnak = 0.75 + (0.00375 [1/mV] - (140 [mM] - extracellular.nao) / 50 [mM] * 0.001 [1/mV]) * membrane.v
    in [1]

[INaL]
GNaL = piecewise(environment.celltype == 1, GNaL_b * multipliers.INaL_multiplier * (1 + fINaLp) * 0.7, GNaL_b * multipliers.INaL_multiplier * (1 + fINaLp))
    in [mS/uF]
GNaL_b = 0.04229 [mS/uF]
    in [mS/uF]
INaL = INaLj + INaLsl
    in [A/F]
INaLj = membrane.Fjunc * GNaL * (membrane.v - reversal_potentials.ENaj) * mL * ((1 - fINaLp) * hL + fINaLp * hLp)
    in [A/F]
INaLsl = membrane.Fsl * GNaL * (membrane.v - reversal_potentials.ENasl) * mL * ((1 - fINaLp) * hL + fINaLp * hLp)
    in [A/F]
fINaLp = CaMK.camk_f_RyR
    in [1]
dot(hL) = (hLss - hL) / thL
    in [1]
dot(hLp) = (hLssp - hLp) / thLp
    in [1]
hLss = 1 / (1 + exp((membrane.v + 87.61 [mV]) / 7.488 [mV]))
    in [1]
hLssp = 1 / (1 + exp((membrane.v + 93.81 [mV]) / 7.488 [mV]))
    in [1]
dot(mL) = (mLss - mL) / tmL
    in [1]
mLss = 1 / (1 + exp(-(membrane.v + 42.85 [mV]) / 5.264 [mV]))
    in [1]
thL = 145 [ms]
    in [ms]
thLp = 3 * thL
    in [ms]
tmL = 0.1292 [ms] * exp(-((membrane.v + 45.79 [mV]) / 15.54 [mV])^2) + 0.06487 [ms] * exp(-((membrane.v - 4.823 [mV]) / 51.12 [mV])^2)
    in [ms]

[INab]
GNab = multipliers.INab_multiplier * GNab_b
    in [mS/uF]
GNab_b = 0.000594 [mS/uF]
    in [mS/uF]
INab = INabj + INabsl
    in [A/F]
INabj = membrane.Fjunc * GNab * (membrane.v - reversal_potentials.ENaj)
    in [A/F]
INabsl = membrane.Fsl * GNab * (membrane.v - reversal_potentials.ENasl)
    in [A/F]

[IpCa]
IbarSLCaP = piecewise(environment.sex == 1, IbarSLCaP_b * 0.8 * multipliers.IpCa_multiplier, environment.sex == 2, IbarSLCaP_b * 1.28 * multipliers.IpCa_multiplier, IbarSLCaP_b * multipliers.IpCa_multiplier)
    in [mS/uF]
IbarSLCaP_b = 0.02064 [mS/uF]
    in [mS/uF]
IpCa = IpCa_junc + IpCa_sl
    in [A/F]
IpCa_junc = membrane.Fjunc * Q10SLCaP^physical_constants.Qpow * IbarSLCaP * intracellular_ions.caj^1.6 / (KmPCa^1.6 + intracellular_ions.caj^1.6)
    in [A/F]
IpCa_sl = membrane.Fsl * Q10SLCaP^physical_constants.Qpow * IbarSLCaP * intracellular_ions.casl^1.6 / (KmPCa^1.6 + intracellular_ions.casl^1.6)
    in [A/F]
KmPCa = 0.0005 [mM]
    in [mM]
Q10SLCaP = 2.35
    in [1]

[Ito]
Gto_fast = piecewise(environment.celltype == 1, 0.29856 * multipliers.Itof_multiplier, environment.celltype == 2, 0.14928 * multipliers.Itof_multiplier, 0.01276 * multipliers.Itof_multiplier)
    in [mS/uF]
Gto_slow = piecewise(environment.celltype == 1, 0.02036 * multipliers.Itos_multiplier, environment.celltype == 2, 0.04632 * multipliers.Itos_multiplier, 0.0721 * multipliers.Itos_multiplier)
    in [mS/uF]
Ito = Itos + Itof
    in [A/F]
Itof = Gto_fast * (membrane.v - reversal_potentials.EK) * ((1 - fItop) * xtof * ytof + fItop * xtof_p * ytof_p)
    in [A/F]
Itos = Gto_slow * (membrane.v - reversal_potentials.EK) * ((1 - fItop) * xtos * ytos + fItop * xtos_p * ytos_p)
    in [A/F]
dti_develop = 1.354 + 0.0001 / (exp((membrane.v - 167.4 [mV]) / 15.89 [mV]) + exp(-(membrane.v - 12.23 [mV]) / 0.2154 [mV]))
    in [1]
dti_recover = 1 - 0.5 / (1 + exp((membrane.v + 70 [mV]) / 20 [mV]))
    in [1]
fItop = CaMK.camk_f_RyR
    in [1]
tauxtof = 8.5 [ms] * exp(-((membrane.v + 45 [mV]) / 50 [mV])^2) + 0.5 [ms]
    in [ms]
tauxtos = 9 [ms] / (1 + exp((membrane.v + 3 [mV]) / 15 [mV])) + 0.5 [ms]
    in [ms]
tauytof = 85 [ms] * exp(-(membrane.v + 40 [mV])^2 / 220 [mV^2]) + 7 [ms]
    in [ms]
tauytof_p = tauytof * dti_develop * dti_recover
    in [ms]
tauytos = 800 [ms] / (1 + exp((membrane.v + 60 [mV]) / 10 [mV])) + 30 [ms]
    in [ms]
tauytos_p = tauytos * dti_develop * dti_recover
    in [ms]
dot(xtof) = (xtoss - xtof) / tauxtof
    in [1]
dot(xtof_p) = (xtoss_p - xtof_p) / tauxtof
    in [1]
dot(xtos) = (xtoss - xtos) / tauxtos
    in [1]
dot(xtos_p) = (xtoss_p - xtos_p) / tauxtos
    in [1]
xtoss = 1 / (1 + exp(-(membrane.v - 19 [mV]) / 13 [mV]))
    in [1]
xtoss_p = 1 / (1 + exp(-(membrane.v - 29 [mV]) / 13 [mV]))
    in [1]
dot(ytof) = (ytoss - ytof) / tauytof
    in [1]
dot(ytof_p) = (ytoss - ytof_p) / tauytof_p
    in [1]
dot(ytos) = (ytoss - ytos) / tauytos
    in [1]
dot(ytos_p) = (ytoss - ytos_p) / tauytos_p
    in [1]
ytoss = 1 / (1 + exp((membrane.v + 19.5 [mV]) / 5 [mV]))
    in [1]

[PKA]
fICaL_PKA = 0
    in [1]
fIKs_PKA = 0
    in [1]
fINaK_PKA = 0
    in [1]
fINa_PKA = 0
    in [1]
fMyBPC_PKA = 0
    in [1]
fPLB_PKA = 0
    in [1]
fTnI_PKA = 0
    in [1]

[SERCA]
Jserca = Jserca_np * (1 - phosphorylationTotal) + Jserca_p * phosphorylationTotal
    in [mM/ms]
Jserca_np = Q10SRCaP^physical_constants.Qpow * Vmax_SRCaP * Vmax_mult * ((intracellular_ions.cai / Kmf)^hillSRCaP - (intracellular_ions.casr / Kmr)^hillSRCaP) / (1 + (intracellular_ions.cai / Kmf)^hillSRCaP + (intracellular_ions.casr / Kmr)^hillSRCaP)
    in [mM/ms]
Jserca_p = Q10SRCaP^physical_constants.Qpow * Vmax_SRCaP * Vmax_mult * ((intracellular_ions.cai / Kmf_p)^hillSRCaP - (intracellular_ions.casr / Kmr)^hillSRCaP) / (1 + (intracellular_ions.cai / Kmf_p)^hillSRCaP + (intracellular_ions.casr / Kmr)^hillSRCaP)
    in [mM/ms]
Km_SERCA_Ca = 0.4 [mM]
    in [mM]
Kmf =  3.06720000000000018e-4 [mM]
    in [mM]
Kmf_p = Kmf * 0.5
    in [mM]
Kmr = 2.31442 [mM]
    in [mM]
Max_Vmax_SERCA_Ca = 1.11142
    in [1]
Q10SRCaP = 2.6
    in [1]
Vmax_SRCaP = piecewise(environment.celltype == 1, 1.2 * Vmax_SRCaP_b * multipliers.Jup_multiplier, Vmax_SRCaP_b * multipliers.Jup_multiplier)
    in [mM/ms]
Vmax_SRCaP_b = 0.00543 [mM/ms]
    in [mM/ms]
Vmax_mult = 1 + Max_Vmax_SERCA_Ca / (1 + (Km_SERCA_Ca / CaMK.casig_SERCA_act)^2)
    in [1]
hillSRCaP = 1.02809
    in [1]
phosphorylationTotal = CaMK.camk_f_PLB + PKA.fPLB_PKA - CaMK.camk_f_PLB * PKA.fPLB_PKA
    in [1]

[cell_geometry]
cellLength = 100 [um]
    in [um]
cellRadius = 10.25 [um]
    in [um]
vcell = 1e-15 [1 (1e+15)] *  3.14159265358979312 * cellRadius^2 * cellLength
    in [L]
vjunc = 0.000539 * vcell
    in [L]
vmyo = 0.65 * vcell
    in [L]
vsl = 0.02 * vcell
    in [L]
vsr = 0.035 * vcell
    in [L]

[contraction]
A = TOT_A * dr / ((1 - dr) * wfrac + dr)
    in [1]
Lfac = piecewise(0 >= 1 + beta_0 * (lambda0 + piecewise(lambda_min <= lambda0, lambda_min, lambda0) - (1 + lambda_min)), 0, 1 + beta_0 * (lambda0 + piecewise(lambda_min <= lambda0, lambda_min, lambda0) - (1 + lambda_min)))
    in [1]
PKAForceMultiplier = 1 + 0.26 * PKA.fMyBPC_PKA
    in [1]
TOT_A = 25
    in [1]
TRPN_n = 1.65
    in [1]
Ta = Lfac * PKAForceMultiplier * Tref / dr * ((contraction_ZETAS + 1) * contraction_XS + contraction_ZETAW * contraction_XW)
    in [Pa (1000)]
Tref = 80 [Pa (1000)]
    in [Pa (1000)]
XSSS = dr * 0.5
    in [1]
XU = 1 - contraction_TmBlocked - contraction_XW - contraction_XS
    in [1]
XWSS = (1 - dr) * wfrac * 0.5
    in [1]
beta_0 = 2.3
    in [1]
beta_1 = -2.4
    in [1]
ca50 = fPKA_TnI * 0.7645 + beta_1 * piecewise(0.2 <= lambda - 1, 0.2, lambda - 1)
    in [1]
cds = phi * k_ws * wfrac * (1 - dr) / dr
    in [1]
cdw = phi * k_uw * (1 - wfrac) / wfrac
    in [1]
dot(contraction_Ca_TRPN) = d_contraction_Ca_TRPN
    in [1]
dot(contraction_TmBlocked) = ktm_block * piecewise(100 <= contraction_Ca_TRPN^(-nperm / 2), 100, contraction_Ca_TRPN^(-nperm / 2)) * XU - ktm_unblock * contraction_Ca_TRPN^(nperm / 2) * contraction_TmBlocked
    in [1]
dot(contraction_XS) = xb_ws - xb_su - xb_su_gamma
    in [1]
dot(contraction_XW) = xb_uw - xb_wu - xb_ws - xb_wu_gamma
    in [1]
dot(contraction_ZETAS) = A * lambda_rate - cds * contraction_ZETAS
    in [1]
dot(contraction_ZETAW) = A * lambda_rate - cdw * contraction_ZETAW
    in [1]
d_contraction_Ca_TRPN = koff * ((intracellular_ions.cai * 1000 [m^3/mol] / ca50)^TRPN_n * (1 - contraction_Ca_TRPN) - contraction_Ca_TRPN)
    in [mS/uF]
dr = 0.25
    in [1]
fPKA_TnI = 1.45 - 0.45 * (1 - PKA.fTnI_PKA) / (1 - fracTnIpo)
    in [1]
fracTnIpo = 0.0031
    in [1]
gamma = 0.0085
    in [1]
gamma_rate = piecewise(contraction_ZETAS > 0, gamma * contraction_ZETAS, contraction_ZETAS < -1, gamma * (-contraction_ZETAS - 1), 0)
    in [1]
gamma_rate_w = gamma_wu * abs(contraction_ZETAW)
    in [1]
gamma_wu = 0.615
    in [1]
k_su = k_ws * (1 / dr - 1) * wfrac
    in [1]
k_uw = 0.026 * nu
    in [1]
k_ws = 0.004 * (1 + PKA.fMyBPC_PKA / 2) * mu
    in [1]
k_wu = k_uw * (1 / wfrac - 1) - k_ws
    in [1]
koff = 0.07854 [mS/uF]
    in [mS/uF]
ktm_block = ktm_unblock * perm50^nperm * 0.5 / (0.5 - XSSS - XWSS)
    in [1]
ktm_unblock = 0.02626
    in [1]
lambda = 1
    in [1]
lambda0 = piecewise(lambda_max <= lambda, lambda_max, lambda)
    in [1]
lambda_max = 1.2
    in [1]
lambda_min = 0.87
    in [1]
lambda_rate = 0 [mS/uF]
    in [mS/uF]
mu = 3.94046
    in [1]
nperm = 2.036
    in [1]
nu = 10.15996
    in [1]
perm50 = 0.35
    in [1]
phi = 2.23
    in [1]
wfrac = 0.5
    in [1]
xb_su = k_su * contraction_XS
    in [1]
xb_su_gamma = gamma_rate * contraction_XS
    in [1]
xb_uw = k_uw * XU * (1 + PKA.fMyBPC_PKA / 2)
    in [1]
xb_ws = k_ws * contraction_XW
    in [1]
xb_wu = k_wu * contraction_XW
    in [1]
xb_wu_gamma = gamma_rate_w * contraction_XW
    in [1]

[environment]
celltype = 0
    in [1]
sex = 0
    in [1]
time = 0 [ms] bind time
    in [ms]

[extracellular]
cao = 1.8 [mM]
    in [mM]
clo = 150 [mM]
    in [mM]
ko = 5 [mM]
    in [mM]
nao = 140 [mM]
    in [mM]

[intracellular_ions]
Bmax_CaM = piecewise(environment.sex == 1, 0.024 [mM] / 1.1, environment.sex == 2, 0.024 [mM] * 1.1, 0.024 [mM])
    in [mM]
Bmax_Csqn =  1.36552139999999989e-1 [mM] * cell_geometry.vmyo / cell_geometry.vsr
    in [mM]
Bmax_Naj = 7.561 [mM]
    in [mM]
Bmax_Nasl = 1.65 [mM]
    in [mM]
Bmax_SLhighj =  1.75754999999999987e-4 [mM] * cell_geometry.vmyo / cell_geometry.vjunc
    in [mM]
Bmax_SLhighsl =  1.21542300000000002e-2 [mM] * cell_geometry.vmyo / cell_geometry.vsl
    in [mM]
Bmax_SLlowj =  4.89983000000000042e-4 [mM] * cell_geometry.vmyo / cell_geometry.vjunc
    in [mM]
Bmax_SLlowsl = 0.033923 [mM] * cell_geometry.vmyo / cell_geometry.vsl
    in [mM]
Bmax_SR =  1.78585399999999991e-2 [mM]
    in [mM]
Bmax_TnChigh = 0.14 [mM]
    in [mM]
Bmax_TnClow = 0.07 [mM]
    in [mM]
Bmax_myosin = 0.14 [mM]
    in [mM]
ICa_tot_junc = ICaL.ICaL_junc + ICab.ICab_junc + IpCa.IpCa_junc - 2 * INaCa.INaCa_ss
    in [A/F]
ICa_tot_sl = ICaL.ICaL_sl + ICab.ICab_sl + IpCa.IpCa_sl - 2 * INaCa.INaCa_i
    in [A/F]
ICl_tot = ICl.IClCa + ICl.IClb
    in [A/F]
IK_tot = Ito.Ito + IKr.IKr + IKs.IKs + IK1.IK1 - 2 * INaK.INaK + ICaL.ICaK + IKb.IKb + membrane.Istim
    in [A/F]
INa_tot_junc = INa.INaj + INaL.INaLj + INab.INabj + 3 * INaCa.INaCa_ss + 3 * INaK.INaKj + ICaL.ICaNa_junc
    in [A/F]
INa_tot_sl = INa.INasl + INaL.INaLsl + INab.INabsl + 3 * INaCa.INaCa_i + 3 * INaK.INaKsl + ICaL.ICaNa_sl
    in [A/F]
I_tot = INa_tot_junc + INa_tot_sl + ICa_tot_junc + ICa_tot_sl + IK_tot + ICl_tot
    in [A/F]
J_CaB_cytosol = d_buffers_TnClow + d_buffers_TnCHc + d_buffers_CaM + d_buffers_Myosin_ca + d_buffers_SRB
    in [mM/ms]
J_CaB_junction = d_buffers_SLLj + d_buffers_SLHj
    in [mM/ms]
J_CaB_sl = d_buffers_SLLsl + d_buffers_SLHsl
    in [mM/ms]
J_ca_juncsl =  3.26067463358168778e-13 [mM/ms]
    in [mM/ms]
J_ca_slmyo =  1.34127367348033708e-11 [mM/ms]
    in [mM/ms]
J_na_juncsl =  1.83127823220607987e-14 [mM/ms]
    in [mM/ms]
J_na_slmyo =  1.63862792221979393e-12 [mM/ms]
    in [mM/ms]
dot(buffers_CaM) = d_buffers_CaM
    in [mM]
dot(buffers_Csqn) = d_buffers_Csqn
    in [mM]
dot(buffers_Myosin_ca) = d_buffers_Myosin_ca
    in [mM]
dot(buffers_Myosin_mg) = kon_myomg * mgi * (Bmax_myosin - buffers_Myosin_ca - buffers_Myosin_mg) - koff_myomg * buffers_Myosin_mg
    in [mM]
dot(buffers_NaBj) = d_buffers_NaBj
    in [mM]
dot(buffers_NaBsl) = d_buffers_NaBsl
    in [mM]
dot(buffers_SLHj) = d_buffers_SLHj
    in [mM]
dot(buffers_SLHsl) = d_buffers_SLHsl
    in [mM]
dot(buffers_SLLj) = d_buffers_SLLj
    in [mM]
dot(buffers_SLLsl) = d_buffers_SLLsl
    in [mM]
dot(buffers_SRB) = d_buffers_SRB
    in [mM]
dot(buffers_TnCHc) = d_buffers_TnCHc
    in [mM]
dot(buffers_TnCHm) = kon_tnchmg * mgi * (Bmax_TnChigh - buffers_TnCHc - buffers_TnCHm) - koff_tnchmg * buffers_TnCHm
    in [mM]
dot(buffers_TnClow) = d_buffers_TnClow
    in [mM]
dot(cai) = -SERCA.Jserca * cell_geometry.vsr / cell_geometry.vmyo - J_CaB_cytosol + J_ca_slmyo / cell_geometry.vmyo * (casl - cai)
    in [mM]
dot(caj) = -ICa_tot_junc * membrane.Cmem / (cell_geometry.vjunc * 2 * physical_constants.F) + J_ca_juncsl / cell_geometry.vjunc * (casl - caj) - J_CaB_junction + ryr.J_SRCarel * cell_geometry.vsr / cell_geometry.vjunc + ryr.J_SRleak * cell_geometry.vmyo / cell_geometry.vjunc
    in [mM]
dot(casl) = -ICa_tot_sl * membrane.Cmem / (cell_geometry.vsl * 2 * physical_constants.F) + J_ca_juncsl / cell_geometry.vsl * (caj - casl) + J_ca_slmyo / cell_geometry.vsl * (cai - casl) - J_CaB_sl
    in [mM]
dot(casr) = SERCA.Jserca - (ryr.J_SRleak * cell_geometry.vmyo / cell_geometry.vsr + ryr.J_SRCarel) - d_buffers_Csqn
    in [mM]
dot(cli) = ICl_tot * membrane.Cmem / (cell_geometry.vmyo * physical_constants.F)
    in [mM]
d_buffers_CaM = kon_cam * cai * (Bmax_CaM - buffers_CaM) - koff_cam * buffers_CaM
    in [mM/ms]
d_buffers_Csqn = kon_csqn * casr * (Bmax_Csqn - buffers_Csqn) - koff_csqn * buffers_Csqn
    in [mM/ms]
d_buffers_Myosin_ca = kon_myoca * cai * (Bmax_myosin - buffers_Myosin_ca - buffers_Myosin_mg) - koff_myoca * buffers_Myosin_ca
    in [mM/ms]
d_buffers_NaBj = kon_na * naj * (Bmax_Naj - buffers_NaBj) - koff_na * buffers_NaBj
    in [mM/ms]
d_buffers_NaBsl = kon_na * nasl * (Bmax_Nasl - buffers_NaBsl) - koff_na * buffers_NaBsl
    in [mM/ms]
d_buffers_SLHj = kon_slh * caj * (Bmax_SLhighj - buffers_SLHj) - koff_slh * buffers_SLHj
    in [mM/ms]
d_buffers_SLHsl = kon_slh * casl * (Bmax_SLhighsl - buffers_SLHsl) - koff_slh * buffers_SLHsl
    in [mM/ms]
d_buffers_SLLj = kon_sll * caj * (Bmax_SLlowj - buffers_SLLj) - koff_sll * buffers_SLLj
    in [mM/ms]
d_buffers_SLLsl = kon_sll * casl * (Bmax_SLlowsl - buffers_SLLsl) - koff_sll * buffers_SLLsl
    in [mM/ms]
d_buffers_SRB = kon_sr * cai * (Bmax_SR - buffers_SRB) - koff_sr * buffers_SRB
    in [mM/ms]
d_buffers_TnCHc = kon_tnchca * cai * (Bmax_TnChigh - buffers_TnCHc - buffers_TnCHm) - koff_tnchca * buffers_TnCHc
    in [mM/ms]
d_buffers_TnClow = Bmax_TnClow * contraction.d_contraction_Ca_TRPN
    in [mM/ms]
dot(ki) = -IK_tot * membrane.Cmem / (cell_geometry.vmyo * physical_constants.F)
    in [mM]
koff_cam = 0.238 [mS/uF]
    in [mS/uF]
koff_csqn = 65 [mS/uF]
    in [mS/uF]
koff_myoca = 0.00046 [mS/uF]
    in [mS/uF]
koff_myomg = 5.7e-5 [mS/uF]
    in [mS/uF]
koff_na = 0.001 [mS/uF]
    in [mS/uF]
koff_slh = 0.03 [mS/uF]
    in [mS/uF]
koff_sll = 1.3 [mS/uF]
    in [mS/uF]
koff_sr = 0.06 [mS/uF]
    in [mS/uF]
koff_tnchca = 3.2e-5 [mS/uF]
    in [mS/uF]
koff_tnchmg = 0.00333 [mS/uF]
    in [mS/uF]
kon_cam = 34 [1/mM/ms]
    in [1/mM/ms]
kon_csqn = 100 [1/mM/ms]
    in [1/mM/ms]
kon_myoca = 13.8 [1/mM/ms]
    in [1/mM/ms]
kon_myomg = 0.0157 [1/mM/ms]
    in [1/mM/ms]
kon_na = 0.0001 [1/mM/ms]
    in [1/mM/ms]
kon_slh = 100 [1/mM/ms]
    in [1/mM/ms]
kon_sll = 100 [1/mM/ms]
    in [1/mM/ms]
kon_sr = 100 [1/mM/ms]
    in [1/mM/ms]
kon_tnchca = 2.37 [1/mM/ms]
    in [1/mM/ms]
kon_tnchmg = 0.003 [1/mM/ms]
    in [1/mM/ms]
mgi = 0.5 [mM]
    in [mM]
dot(nai) = J_na_slmyo / cell_geometry.vmyo * (nasl - nai)
    in [mM]
dot(naj) = -INa_tot_junc * membrane.Cmem / (cell_geometry.vjunc * physical_constants.F) + J_na_juncsl / cell_geometry.vjunc * (nasl - naj) - d_buffers_NaBj
    in [mM]
dot(nasl) = -INa_tot_sl * membrane.Cmem / (cell_geometry.vsl * physical_constants.F) + J_na_juncsl / cell_geometry.vsl * (naj - nasl) + J_na_slmyo / cell_geometry.vsl * (nai - nasl) - d_buffers_NaBsl
    in [mM]

[membrane]
Cmem = 1.381e-10 [F]
    in [F]
Fjunc = 0.11
    in [1]
Fsl = 1 - Fjunc
    in [1]
Istim = pace * i_Stim_Amplitude
    in [A/F]
i_Stim_Amplitude = -53 [A/F]
    in [A/F]
pace = 0 bind pace
    in [1]
dot(v) = -intracellular_ions.I_tot
    in [mV]
vffrt = v * physical_constants.F * physical_constants.F / (physical_constants.R * physical_constants.T)
    in [C/mol]
vfrt = v * physical_constants.F / (physical_constants.R * physical_constants.T)
    in [1]

[multipliers]
ICaLPCa_multiplier = 1
    in [1]
ICab_multiplier = 1
    in [1]
IClCa_multiplier = 1
    in [1]
IClb_multiplier = 1
    in [1]
IK1_multiplier = 1
    in [1]
IKb_multiplier = 1
    in [1]
IKr_multiplier = 1
    in [1]
IKs_multiplier = 1
    in [1]
INaCa_multiplier = 1
    in [1]
INaK_multiplier = 1
    in [1]
INaL_multiplier = 1
    in [1]
INa_multiplier = 1
    in [1]
INab_multiplier = 1
    in [1]
IpCa_multiplier = 1
    in [1]
Itof_multiplier = 1
    in [1]
Itos_multiplier = 1
    in [1]
Jrel_multiplier = 1
    in [1]
Jup_multiplier = 1
    in [1]

[physical_constants]
F = 96485 [C/mol]
    in [C/mol]
Qpow = (T - 310) / 10
    in [1]
R = 8314 [mJ/mol/K]
    in [mJ/mol/K]
T = 310 [K]
    in [K]
zca = 2
    in [1]
zcl = -1
    in [1]
zk = 1
    in [1]
zna = 1
    in [1]

[reversal_potentials]
ECaj = physical_constants.R * physical_constants.T / (physical_constants.zca * physical_constants.F) * log(extracellular.cao / intracellular_ions.caj)
    in [mV]
ECasl = physical_constants.R * physical_constants.T / (physical_constants.zca * physical_constants.F) * log(extracellular.cao / intracellular_ions.casl)
    in [mV]
ECl = physical_constants.R * physical_constants.T / (physical_constants.zcl * physical_constants.F) * log(extracellular.clo / intracellular_ions.cli)
    in [mV]
EK = physical_constants.R * physical_constants.T / (physical_constants.zk * physical_constants.F) * log(extracellular.ko / intracellular_ions.ki)
    in [mV]
EKs = physical_constants.R * physical_constants.T / (physical_constants.zk * physical_constants.F) * log((extracellular.ko + PNaK * extracellular.nao) / (intracellular_ions.ki + PNaK * intracellular_ions.nai))
    in [mV]
ENaj = physical_constants.R * physical_constants.T / (physical_constants.zna * physical_constants.F) * log(extracellular.nao / intracellular_ions.naj)
    in [mV]
ENasl = physical_constants.R * physical_constants.T / (physical_constants.zna * physical_constants.F) * log(extracellular.nao / intracellular_ions.nasl)
    in [mV]
PNaK = 0.01833
    in [1]

[ryr]
CI_to_RI = 0.00248 [mS/uF]
    in [mS/uF]
CaMKIILeakMultiplier = 1 + 2 * CaMK.camk_f_RyR
    in [1]
ICaL_junc_positive = abs(ICaL.ICaL_junc)
    in [A/F]
ICaL_junc_sigmoided = 1 - 1 / (1 + (ICaL_junc_positive / 0.45 [A/F])^4.5)
    in [1]
J_SRCarel = J_SRCarel_p * CaMK.camk_f_RyR + J_SRCarel_np * (1 - CaMK.camk_f_RyR)
    in [mM/ms]
J_SRCarel_np = ks * ryr_O * (intracellular_ions.casr - intracellular_ions.caj) + Jrel_ICaLdep
    in [mM/ms]
J_SRCarel_p = ks * ryr_O_p * (intracellular_ions.casr - intracellular_ions.caj) + Jrel_ICaLdep
    in [mM/ms]
J_SRleak =  1.59306000000000000e-6 [mS/uF] * (intracellular_ions.casr - intracellular_ions.caj) * nonlinearModifier * CaMKIILeakMultiplier
    in [mM/ms]
Jrel_ICaLdep = 0.00174 [mM/ms] * jrel_icaldep_act * jrel_icaldep_f1 * jrel_icaldep_f2
    in [mM/ms]
Jrel_inact_inf = 1 / (1 + ICaL_junc_sigmoided / 0.001)
    in [1]
Jrel_inact_inf2 = 1 / (1 + ICaL_junc_sigmoided / 0.0006)
    in [1]
Jrel_inf = a_rel * ICaL_junc_sigmoided / (1 + (directRelMidpoint / intracellular_ions.casr)^7.72672)
    in [1]
MaxSR = 15
    in [1]
MinSR = 1
    in [1]
RI_to_CI = baseRateCaI * sigmoidBaseCaI
    in [mS/uF]
RIcleft = 1 - ryr_R - ryr_O - ryr_I - ryr_CaRI
    in [1]
RIcleft_p = 1 - ryr_R_p - ryr_O_p - ryr_I_p - ryr_CaRI_p
    in [1]
a_rel = 1.25 * bt / 1 [ms]
    in [1]
baseRateCaI =  3.02320000000000019e-4 [mS/uF]
    in [mS/uF]
bt = 12.4767 [ms]
    in [ms]
caExpFactor = 0.68655
    in [1]
caExpFactor2 = 2.06273
    in [1]
caTransFactor = 0.94428 [mS/uF]
    in [mS/uF]
caTransFactor2 = 0.52967 [mS/uF]
    in [mS/uF]
caTransFactor2p = caTransFactor2 * 1.5
    in [mS/uF]
directRelMidpoint = 0.95271 [mM]
    in [mM]
ec50SR = 0.75385 [mM]
    in [mM]
ecCaI = 0.001 [mM]
    in [mM]
dot(jrel_icaldep_act) = (Jrel_inf - jrel_icaldep_act) / tau_rel
    in [mM/ms]
dot(jrel_icaldep_f1) = (Jrel_inact_inf - jrel_icaldep_f1) / tauInact
    in [1]
dot(jrel_icaldep_f2) = (Jrel_inact_inf2 - jrel_icaldep_f2) / tauInact2
    in [1]
kCaSR = MaxSR - (MaxSR - MinSR) / (1 + (ec50SR / intracellular_ions.casr)^steepnessCaSR)
    in [1]
kiCa = 0.39871
    in [1]
kiSRCa = kiCa * kCaSR
    in [1]
kim = 0.04311 [mS/uF]
    in [mS/uF]
koCa = 23.87221
    in [1]
koSRCa = koCa / kCaSR
    in [1]
kom = 0.16219 [mS/uF]
    in [mS/uF]
ks = multipliers.Jrel_multiplier * 26.6 [mS/uF]
    in [mS/uF]
maxCaI = 30.13294
    in [1]
minCaI = 0.93249
    in [1]
nonlinearModifier = 0.2144 * exp(1.83 [m^3/mol] * intracellular_ions.casr)
    in [1]
dot(ryr_CaRI) = RI_to_CI * RIcleft - CI_to_RI * ryr_CaRI
    in [1]
dot(ryr_CaRI_p) = RI_to_CI * RIcleft_p - CI_to_RI * ryr_CaRI_p
    in [1]
dot(ryr_I) = kiSRCa * caTransFactor * (intracellular_ions.caj / 1 [mM])^caExpFactor * ryr_O - kim * ryr_I - (kom * ryr_I - caTransFactor2 * koSRCa * (intracellular_ions.caj / 1 [mM])^caExpFactor2 * RIcleft)
    in [1]
dot(ryr_I_p) = kiSRCa * caTransFactor * (intracellular_ions.caj / 1 [mM])^caExpFactor * ryr_O_p - kim * ryr_I_p - (kom * ryr_I_p - caTransFactor2p * koSRCa * (intracellular_ions.caj / 1 [mM])^caExpFactor2 * RIcleft_p)
    in [1]
dot(ryr_O) = caTransFactor2 * koSRCa * (intracellular_ions.caj / 1 [mM])^caExpFactor2 * ryr_R - kom * ryr_O - (kiSRCa * caTransFactor * (intracellular_ions.caj / 1 [mM])^caExpFactor * ryr_O - kim * ryr_I)
    in [1]
dot(ryr_O_p) = caTransFactor2 * koSRCa * (intracellular_ions.caj / 1 [mM])^caExpFactor2 * ryr_R_p - kom * ryr_O_p - (kiSRCa * caTransFactor * (intracellular_ions.caj / 1 [mM])^caExpFactor * ryr_O_p - kim * ryr_I_p)
    in [1]
dot(ryr_R) = kim * RIcleft - kiSRCa * caTransFactor * (intracellular_ions.caj / 1 [mM])^caExpFactor * ryr_R - (caTransFactor2 * koSRCa * (intracellular_ions.caj / 1 [mM])^caExpFactor2 * ryr_R - kom * ryr_O)
    in [1]
dot(ryr_R_p) = kim * RIcleft_p - kiSRCa * caTransFactor * (intracellular_ions.caj / 1 [mM])^caExpFactor * ryr_R_p - (caTransFactor2p * koSRCa * (intracellular_ions.caj / 1 [mM])^caExpFactor2 * ryr_R_p - kom * ryr_O_p)
    in [1]
sigmoidBaseCaI = minCaI + (maxCaI - minCaI) / (1 + (ecCaI / intracellular_ions.caj)^steepnessCaI)
    in [1]
steepnessCaI = 5.93447
    in [1]
steepnessCaSR = 5.09473
    in [1]
tauInact = 64.11202 [ms]
    in [ms]
tauInact2 = 119.48978 [ms]
    in [ms]
tau_rel = piecewise(0.001 [ms] >= bt / (1 + 0.0123 [mM] / intracellular_ions.casr), 0.001 [ms], bt / (1 + 0.0123 [mM] / intracellular_ions.casr))
    in [ms]

