tfs =  2.71922488999999996e3 [ms] + 1 [ms] / ( 7.19411000000000014e-5 * exp(-(membrane.v + 5.74631 [mV]) / 10.8769 [mV]) +  7.19411000000000014e-5 * exp((membrane.v + 5.74631 [mV]) / 16.31535 [mV]))
