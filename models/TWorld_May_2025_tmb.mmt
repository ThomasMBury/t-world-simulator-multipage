beta_i = 0.04568 [mS/uF] * exp(-0.8209 * membrane.vfrt)
    in [mS/uF]
celltype_factor = piecewise(environment.celltype == 1, 1.25, environment.celltype == 2, 0.7, 1)
    in [1]
sex_factor = piecewise(environment.sex == 1, 1.1, environment.sex == 2, 0.87, 1)
