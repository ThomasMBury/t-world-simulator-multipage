fINa_P = PKA.fINa_PKA
    in [1]
fINa_PKAonly = fINa_P - fINa_BP
    in [1]
fINap = CaMK.camk_f_RyR
    in [1]
dot(h) = (hss - h) / th
    in [1]
dot(h_P) = (hss_P - h_P) / th
    in [1]
dot(hp) = (hssp - hp) / th
    in [1]
dot(hp_P) = (hssp_P - hp_P) / th
    in [1]
hss = 1 / (1 + exp((membrane.v + 71.55 [mV]) / 7.43 [mV]))^2
    in [1]
hss_P = 1 / (1 + exp((membrane.v + 76.55 [mV]) / 7.43 [mV]))^2
    in [1]
hssp = 1 / (1 + exp((membrane.v + 77.55 [mV]) / 7.43 [mV]))^2
    in [1]
hssp_P = 1 / (1 + exp((membrane.v + 82.55 [mV]) / 7.43 [mV]))^2
    in [1]
dot(j) = (jss - j) / tj
    in [1]
dot(j_P) = (jss_P - j_P) / tj
    in [1]
dot(jp) = (jss - jp) / tjp
    in [1]
dot(jp_P) = (jssp_P - jp_P) / tjp
    in [1]
jss = hss
    in [1]
jss_P = hss_P
    in [1]
jssp_P = hssp_P
    in [1]
dot(m) = (mss - m) / tm
    in [1]
dot(m_P) = (mss_P - m_P) / tm
