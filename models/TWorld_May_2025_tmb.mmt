tm = 0.1292 [ms] * exp(-((membrane.v + 45.79 [mV]) / 15.54 [mV])^2) + 0.06487 [ms] * exp(-((membrane.v - 4.823 [mV]) / 51.12 [mV])^2)
    in [ms]

[INaCa]
E1_i = x1_i / (x1_i + x2_i + x3_i + x4_i)
