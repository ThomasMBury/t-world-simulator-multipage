intracellular_ions.casl              =  9.62428218317655005e-5
intracellular_ions.cai               =  9.66105402693763000e-5
INa.m                                =  1.15997496446638006e-3
INa.h                                =  7.91660456106285992e-1
INa.j                                =  7.91587530878067991e-1
INa.hp                               =  6.12409807882460022e-1
INa.jp                               =  7.91052149435448992e-1
INa.m_P                              =  3.34028683421829994e-3
INa.h_P                              =  6.47375310489835987e-1
INa.j_P                              =  6.47279109941896968e-1
INa.hp_P                             =  4.19158183843564014e-1
INa.jp_P                             =  4.18669666153645981e-1
INaL.mL                              =  2.24902633151065996e-4
INaL.hL                              =  4.78572465113524026e-1
INaL.hLp                             =  2.58793079229037992e-1
ICaL.d                               =  6.00992839633468041e-26
ICaL.ff                              =  9.99999988243592042e-1
ICaL.fs                              =  9.11094950010905014e-1
ICaL.fcaf                            =  9.99999988251085048e-1
ICaL.fcas                            =  9.91477881027688968e-1
ICaL.jca                             =  9.99993204834444982e-1
ICaL.ffp                             =  9.99999987868131046e-1
ICaL.fcafp                           =  9.99999987980700999e-1
ICaL.nca                             =  5.28788208273222975e-3
ICaL.nca_i                           =  6.21547539490541028e-3
ICaL.d_P                             = 0
ICaL.ff_P                            =  9.99999987992091000e-1
ICaL.fs_P                            =  9.30411822666438959e-1
ICaL.fcaf_P                          =  9.99999987985881966e-1
ICaL.fcas_P                          =  9.99145398038995047e-1
ICaL.fBPf                            =  9.99999987992091000e-1
ICaL.fcaBPf                          =  9.99999987985881966e-1
ICaL.ical_pureCDI_junc               =  9.98342275864489981e-1
ICaL.ical_pureCDI_sl                 =  9.98263185911480000e-1
Ito.xtos                             =  2.86101402392893993e-4
Ito.ytos                             =  7.68184915918178945e-1
Ito.xtof                             =  2.86099374494749989e-4
Ito.ytof                             =  9.99998646875180031e-1
Ito.xtos_p                           =  1.32590983159417000e-4
Ito.xtof_p                           =  1.32590043205026988e-4
Ito.ytos_p                           =  7.77117031645023992e-1
Ito.ytof_p                           =  9.99998646879750042e-1
IKr.C0                               =  9.97558791218494001e-1
IKr.C1                               =  9.60122333286174043e-4
IKr.C2                               =  8.04204051120587025e-4
IKr.I                                =  3.55901681542090999e-5
IKr.O                                =  6.41292278097939979e-4
IKs.xs_junc                          =  3.11875010014238986e-2
IKs.xs_sl                            =  3.12048105743730000e-2
ryr.jrel_icaldep_act                 = -9.23949112019060968e-15
ryr.jrel_icaldep_f1                  =  9.99994847409610976e-1
ryr.jrel_icaldep_f2                  =  9.98725931920675047e-1
ryr.ryr_R                            =  8.21525956842405036e-1
ryr.ryr_O                            =  3.33929041065478997e-8
ryr.ryr_I                            =  4.57362306340243018e-9
ryr.ryr_CaRI                         =  6.53313479138347974e-2
ryr.ryr_R_p                          =  8.21663945287199993e-1
ryr.ryr_O_p                          =  5.00978004918836978e-8
ryr.ryr_I_p                          =  6.86118926495390029e-9
ryr.ryr_CaRI_p                       =  6.51828099424918983e-2
contraction.contraction_TmBlocked    =  9.92378492940848012e-1
contraction.contraction_XW           =  2.85370717430549021e-3
contraction.contraction_XS           =  1.91507884532543006e-3
contraction.contraction_ZETAS        = 0
contraction.contraction_ZETAW        = 0
contraction.contraction_Ca_TRPN      =  3.19778784167467980e-2

[CaMK]
CaMK0 = 0.1
    in [1]
CaMK_Phos_ss_ICaL = CaMK_active / (CaMK_active + K_Phos_CaMK)
    in [1]
CaMK_Phos_ss_PLB = CaMK_active / (CaMK_active + 10 [mM])
    in [1]
CaMK_Phos_ss_RyR = CaMK_active / (CaMK_active + 1 [mM])
    in [1]
CaMK_active = bound + camk_trap
    in [mM]
K_Phos_CaMK = 0.35 [mM]
    in [mM]
Km_CaMK_Ca = 0.0075 [mM]
    in [mM]
PP1_tot = Whole_cell_PP1
    in [1]
Whole_cell_PP1 = 0.13698
    in [1]
alpha = 0.05 [1/mM/ms]
    in [1/mM/ms]
alpha_serca = 0.05 [1/mM/ms]
    in [1/mM/ms]
beta = 0.00068 [mS/uF]
    in [mS/uF]
bound = CaMK0 * (1 [mM] - camk_trap) / (1 + Km_CaMK_Ca / intracellular_ions.caj)
    in [mM]
bound_serca = CaMK0 * (1 [mM] - casig_serca_trap) / (1 + Km_CaMK_Ca / intracellular_ions.caj)
    in [mM]
dot(camk_f_ICaL) = (CaMK_Phos_ss_ICaL - camk_f_ICaL) / tau_cal
    in [1]
dot(camk_f_PLB) = (CaMK_Phos_ss_PLB - camk_f_PLB) / tau_plb
    in [1]
dot(camk_f_RyR) = (CaMK_Phos_ss_RyR - camk_f_RyR) / tau_ryr
    in [1]
dot(camk_trap) = alpha * bound * CaMK_active - beta * camk_trap * (0.1 + 0.9 * PP1_tot / 0.1371)
    in [mM]
casig_SERCA_act = bound_serca + casig_serca_trap
    in [mM]
dot(casig_serca_trap) = alpha_serca * bound_serca * casig_SERCA_act - beta * casig_serca_trap * (0.1 + 0.9 * PP1_tot / 0.1371)
    in [mM]
tau_cal = tau_ryr
    in [ms]
tau_plb = 100000 [ms]
    in [ms]
tau_ryr = 10000 [ms]
    in [ms]

[ICaL]
Afcaf = 0.3 + 0.6 / (1 + exp((membrane.v - 9.24247 [mV]) / 27.96201 [mV]))
    in [1]
Afcas = 1 - Afcaf
    in [1]
Aff = 0.52477
    in [1]
Afs = 1 - Aff
    in [1]
ICaK = ICaK_junc + ICaK_sl
    in [A/F]
ICaK_i_BP = PCaK_P * PhiCaK_i * d_P * (fBP * (1 - nca_i) + jca * fcaBP * nca_i)
    in [A/F]
ICaK_i_CaMK = PCaKp * PhiCaK_i * d * (fp * (1 - nca_i) + jca * fcap * nca_i)
    in [A/F]
ICaK_i_NP = PCaK * PhiCaK_i * d * (f * (1 - nca_i) + jca * fca * nca_i)
    in [A/F]
ICaK_i_PKA = PCaK_P * PhiCaK_i * d_P * (f_P * (1 - nca_i) + jca * fcap_P * nca_i)
    in [A/F]
ICaK_junc = ((1 - fICaL_CaMKonly - fICaL_PKAonly - fICaL_BP) * ICaK_ss_NP + fICaL_CaMKonly * ICaK_ss_CaMK + fICaL_PKAonly * ICaK_ss_PKA + fICaL_BP * ICaK_ss_BP) * ical_pureCDI_junc * ICaL_fractionSS
    in [A/F]
ICaK_sl = ((1 - fICaL_CaMKonly - fICaL_PKAonly - fICaL_BP) * ICaK_i_NP + fICaL_CaMKonly * ICaK_i_CaMK + fICaL_PKAonly * ICaK_i_PKA + fICaL_BP * ICaK_i_BP) * ical_pureCDI_sl * (1 - ICaL_fractionSS)
    in [A/F]
ICaK_ss_BP = PCaK_P * PhiCaK_ss * d_P * (fBP * (1 - nca) + jca * fcaBP * nca)
    in [A/F]
ICaK_ss_CaMK = PCaKp * PhiCaK_ss * d * (fp * (1 - nca) + jca * fcap * nca)
    in [A/F]
ICaK_ss_NP = PCaK * PhiCaK_ss * d * (f * (1 - nca) + jca * fca * nca)
    in [A/F]
ICaK_ss_PKA = PCaK_P * PhiCaK_ss * d_P * (f_P * (1 - nca) + jca * fcap_P * nca)
    in [A/F]
ICaL = ICaL_junc + ICaL_sl
    in [A/F]
ICaL_fractionSS = 0.8
    in [1]
ICaL_i_BP = PCa_P * PhiCaL_i * d_P * (fBP * (1 - nca_i) + jca * fcaBP * nca_i)
    in [A/F]
ICaL_i_CaMK = PCap * PhiCaL_i * d * (fp * (1 - nca_i) + jca * fcap * nca_i)
    in [A/F]
ICaL_i_NP = PCa * PhiCaL_i * d * (f * (1 - nca_i) + jca * fca * nca_i)
    in [A/F]
ICaL_i_PKA = PCa_P * PhiCaL_i * d_P * (f_P * (1 - nca_i) + jca * fcap_P * nca_i)
    in [A/F]
ICaL_junc = ((1 - fICaL_CaMKonly - fICaL_PKAonly - fICaL_BP) * ICaL_ss_NP + fICaL_CaMKonly * ICaL_ss_CaMK + fICaL_PKAonly * ICaL_ss_PKA + fICaL_BP * ICaL_ss_BP) * ical_pureCDI_junc * ICaL_fractionSS
    in [A/F]
ICaL_sl = ((1 - fICaL_CaMKonly - fICaL_PKAonly - fICaL_BP) * ICaL_i_NP + fICaL_CaMKonly * ICaL_i_CaMK + fICaL_PKAonly * ICaL_i_PKA + fICaL_BP * ICaL_i_BP) * ical_pureCDI_sl * (1 - ICaL_fractionSS)
    in [A/F]
ICaL_ss_BP = PCa_P * PhiCaL_ss * d_P * (fBP * (1 - nca) + jca * fcaBP * nca)
    in [A/F]
ICaL_ss_CaMK = PCap * PhiCaL_ss * d * (fp * (1 - nca) + jca * fcap * nca)
    in [A/F]
ICaL_ss_NP = PCa * PhiCaL_ss * d * (f * (1 - nca) + jca * fca * nca)
    in [A/F]
ICaL_ss_PKA = PCa_P * PhiCaL_ss * d_P * (f_P * (1 - nca) + jca * fcap_P * nca)
    in [A/F]
ICaNa = ICaNa_junc + ICaNa_sl
    in [A/F]
ICaNa_i_BP = PCaNa_P * PhiCaNa_i * d_P * (fBP * (1 - nca_i) + jca * fcaBP * nca_i)
    in [A/F]
ICaNa_i_CaMK = PCaNap * PhiCaNa_i * d * (fp * (1 - nca_i) + jca * fcap * nca_i)
    in [A/F]
ICaNa_i_NP = PCaNa * PhiCaNa_i * d * (f * (1 - nca_i) + jca * fca * nca_i)
    in [A/F]
ICaNa_i_PKA = PCaNa_P * PhiCaNa_i * d_P * (f_P * (1 - nca_i) + jca * fcap_P * nca_i)
    in [A/F]
ICaNa_junc = ((1 - fICaL_CaMKonly - fICaL_PKAonly - fICaL_BP) * ICaNa_ss_NP + fICaL_CaMKonly * ICaNa_ss_CaMK + fICaL_PKAonly * ICaNa_ss_PKA + fICaL_BP * ICaNa_ss_BP) * ical_pureCDI_junc * ICaL_fractionSS
    in [A/F]
ICaNa_sl = ((1 - fICaL_CaMKonly - fICaL_PKAonly - fICaL_BP) * ICaNa_i_NP + fICaL_CaMKonly * ICaNa_i_CaMK + fICaL_PKAonly * ICaNa_i_PKA + fICaL_BP * ICaNa_i_BP) * ical_pureCDI_sl * (1 - ICaL_fractionSS)
    in [A/F]
ICaNa_ss_BP = PCaNa_P * PhiCaNa_ss * d_P * (fBP * (1 - nca) + jca * fcaBP * nca)
    in [A/F]
ICaNa_ss_CaMK = PCaNap * PhiCaNa_ss * d * (fp * (1 - nca) + jca * fcap * nca)
    in [A/F]
ICaNa_ss_NP = PCaNa * PhiCaNa_ss * d * (f * (1 - nca) + jca * fca * nca)
    in [A/F]
ICaNa_ss_PKA = PCaNa_P * PhiCaNa_ss * d_P * (f_P * (1 - nca) + jca * fcap_P * nca)
    in [A/F]
ICa_tot = ICaL + ICaK + ICaNa
    in [A/F]
Ii = 0.5 * (intracellular_ions.nai + intracellular_ions.ki + intracellular_ions.cli + 4 * intracellular_ions.cai) / 1000 [mM]
    in [1]
Io = 0.5 * (extracellular.nao + extracellular.ko + extracellular.clo + 4 * extracellular.cao) / 1000 [mM]
    in [1]
Iss = 0.5 * (intracellular_ions.nasl + intracellular_ions.ki + intracellular_ions.cli + 4 * intracellular_ions.casl) / 1000 [mM]
    in [1]
Kmn = 0.00222 [mM]
    in [mM]
PCa = piecewise(environment.celltype == 1, PCa_b * multipliers.ICaLPCa_multiplier * 1.025, environment.celltype == 2, PCa_b * multipliers.ICaLPCa_multiplier * 1.1, PCa_b * multipliers.ICaLPCa_multiplier)
    in [1]
PCaK =  2.21139954662870998e-4 * PCa
    in [1]
PCaK_P =  2.21139954662870998e-4 * PCa_P
    in [1]
PCaKp =  2.21139954662870998e-4 * PCap
    in [1]
PCaNa =  7.73432969581949454e-4 * PCa
    in [1]
PCaNa_P =  7.73432969581949454e-4 * PCa_P
    in [1]
PCaNap =  7.73432969581949454e-4 * PCap
    in [1]
PCa_P = piecewise(environment.celltype == 1, PCa_Pb * 1.025, environment.celltype == 2, PCa_Pb * 1.1, PCa_Pb)
    in [1]
PCa_Pb = 1.9 * PCa
    in [1]
PCa_b =  1.57679999999999995e-4
    in [1]
PCap = 1.1 * PCa
    in [1]
PhiCaK_i = 1 * membrane.vffrt * (gamma_ki * intracellular_ions.ki * exp(1 * membrane.vfrt) - gamma_ko * extracellular.ko) / (exp(1 * membrane.vfrt) - 1)
    in [1]
PhiCaK_ss = 1 * membrane.vffrt * (gamma_kss * intracellular_ions.ki * exp(1 * membrane.vfrt) - gamma_ko * extracellular.ko) / (exp(1 * membrane.vfrt) - 1)
    in [1]
PhiCaL_i = 4 * membrane.vffrt * (gamma_cai * intracellular_ions.cai * exp(2 * membrane.vfrt) - gamma_cao * extracellular.cao) / (exp(2 * membrane.vfrt) - 1)
    in [1]
PhiCaL_ss = 4 * membrane.vffrt * (gamma_cass * intracellular_ions.casl * exp(2 * membrane.vfrt) - gamma_cao * extracellular.cao) / (exp(2 * membrane.vfrt) - 1)
    in [1]
PhiCaNa_i = 1 * membrane.vffrt * (gamma_nai * intracellular_ions.nai * exp(1 * membrane.vfrt) - gamma_nao * extracellular.nao) / (exp(1 * membrane.vfrt) - 1)
    in [1]
PhiCaNa_ss = 1 * membrane.vffrt * (gamma_nass * intracellular_ions.nasl * exp(1 * membrane.vfrt) - gamma_nao * extracellular.nao) / (exp(1 * membrane.vfrt) - 1)
    in [1]
anca = 1 / (k2n / km2n + (1 + Kmn / intracellular_ions.caj)^3.80763)
    in [1]
anca_i = 1 / (k2n / km2n + (1 + Kmn / intracellular_ions.casl)^3.80763)
    in [1]
constA = 1820000 * (dielConstant * physical_constants.T)^(-1.5)
    in [1]
dot(d) = (dss - d) / td
    in [1]
dPss = piecewise(1 <= 1.0323 * exp(-1.0553 * exp(-0.081 [1/mV] * (membrane.v + 12.62483 [mV]))), 1, 1.0323 * exp(-1.0553 * exp(-0.081 [1/mV] * (membrane.v + 12.62483 [mV]))))
    in [1]
dot(d_P) = (dPss - d_P) / td
    in [1]
dielConstant = 74 [1/K]
    in [1/K]
dss = piecewise(1 <= 1.0763 * exp(-1.007 * exp(-0.0829 [1/mV] * (membrane.v + 3.62483 [mV]))), 1, 1.0763 * exp(-1.007 * exp(-0.0829 [1/mV] * (membrane.v + 3.62483 [mV]))))
    in [1]
f = Aff * ff + Afs * fs
    in [1]
fBP = Aff * fBPf + Afs * fs_P
    in [1]
dot(fBPf) = (fBPss - fBPf) / tffp
    in [1]
fBPss = fss_P
    in [1]
fICaLP = PKA.fICaL_PKA
    in [1]
fICaL_BP = fICaLp * fICaL_P
    in [1]
fICaL_CaMKonly = fICaLp - fICaL_BP
    in [1]
fICaL_P = fICaLP
    in [1]
fICaL_PKAonly = fICaL_P - fICaL_BP
    in [1]
fICaLp = CaMK.camk_f_ICaL
    in [1]
f_P = Aff * ff_P + Afs * fs_P
    in [1]
fca = Afcaf * fcaf + Afcas * fcas
    in [1]
fcaBP = Afcaf * fcaBPf + Afcas * fcas_P
    in [1]
dot(fcaBPf) = (fcaBPss - fcaBPf) / tfcafp
    in [1]
fcaBPss = fcass_P
    in [1]
dot(fcaf) = (fcass - fcaf) / tfcaf
    in [1]
dot(fcaf_P) = (fcass_P - fcaf_P) / tfcaf
    in [1]
dot(fcafp) = (fcass - fcafp) / tfcafp
    in [1]
fcap = Afcaf * fcafp + Afcas * fcas
    in [1]
fcap_P = Afcaf * fcaf_P + Afcas * fcas_P
    in [1]
dot(fcas) = (fcass - fcas) / tfcas
    in [1]
dot(fcas_P) = (fcass_P - fcas_P) / tfcas
    in [1]
fcass = fss
    in [1]
fcass_P = fss_P
    in [1]
dot(ff) = (fss - ff) / tff
    in [1]
dot(ff_P) = (fss_P - ff_P) / tff
    in [1]
dot(ffp) = (fss - ffp) / tffp
    in [1]
fp = Aff * ffp + Afs * fs
    in [1]
dot(fs) = (fss - fs) / tfs
    in [1]
dot(fs_P) = (fss_P - fs_P) / tfs
    in [1]
fss = 1 / (1 + exp((membrane.v + 19.58 [mV]) / 3.696 [mV]))
    in [1]
fss_P = 1 / (1 + exp((membrane.v + 25.58 [mV]) / 3.696 [mV]))
    in [1]
gamma_cai = 10^(-constA * 4 * (sqrt(Ii) / (1 + sqrt(Ii)) - 0.3 * Ii))
    in [1]
gamma_cao = 10^(-constA * 4 * (sqrt(Io) / (1 + sqrt(Io)) - 0.3 * Io))
    in [1]
gamma_cass = 10^(-constA * 4 * (sqrt(Iss) / (1 + sqrt(Iss)) - 0.3 * Iss))
    in [1]
gamma_ki = 10^(-constA * 1 * (sqrt(Ii) / (1 + sqrt(Ii)) - 0.3 * Ii))
    in [1]
gamma_ko = 10^(-constA * 1 * (sqrt(Io) / (1 + sqrt(Io)) - 0.3 * Io))
    in [1]
gamma_kss = 10^(-constA * 1 * (sqrt(Iss) / (1 + sqrt(Iss)) - 0.3 * Iss))
    in [1]
gamma_nai = 10^(-constA * 1 * (sqrt(Ii) / (1 + sqrt(Ii)) - 0.3 * Ii))
    in [1]
gamma_nao = 10^(-constA * 1 * (sqrt(Io) / (1 + sqrt(Io)) - 0.3 * Io))
    in [1]
gamma_nass = 10^(-constA * 1 * (sqrt(Iss) / (1 + sqrt(Iss)) - 0.3 * Iss))
    in [1]
dot(ical_pureCDI_junc) = -ical_pureCDI_junc * sigmoidTransition / tauTransition + (1 - ical_pureCDI_junc) * rateRecovery
    in [1]
dot(ical_pureCDI_sl) = -ical_pureCDI_sl * sigmoidTransition2 / tauTransition2 + (1 - ical_pureCDI_sl) * rateRecovery
    in [1]
dot(jca) = (jcass - jca) / tjca
    in [1]
jcass = 1 / (1 + exp((membrane.v + 17.66945 [mV]) / 3.21501 [mV]))
    in [1]
k2n = 957.85903 [mS/uF]
    in [mS/uF]
km2n = jca * 0.84191 [mS/uF]
    in [mS/uF]
dot(nca) = anca * k2n - nca * km2n
    in [1]
dot(nca_i) = anca_i * k2n - nca_i * km2n
    in [1]
rateRecovery = 0.02313 [mS/uF]
    in [mS/uF]
sigmoidTransition = 1 - 1 / (1 + 1.86532 * intracellular_ions.caj / 0.032 [mM])
    in [1]
sigmoidTransition2 = 1 - 1 / (1 + 1.86532 * intracellular_ions.casl / 0.032 [mM])
    in [1]
tauTransition = 1.0967 [ms] + (1 - sigmoidTransition) * 141.4299 [ms]
