mss = 1 / (1 + exp(-(membrane.v + 56.86 [mV]) / 9.03 [mV]))^2
    in [1]
mss_P = 1 / (1 + exp(-(membrane.v + 61.86 [mV]) / 9.03 [mV]))^2
    in [1]
th = 1 [ms] / (ah + bh)
