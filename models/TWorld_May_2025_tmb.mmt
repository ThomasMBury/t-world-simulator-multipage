INaBase = (1 - fINa_CaMKonly - fINa_PKAonly - fINa_BP) * INaBase_NP + fINa_CaMKonly * INaBase_CaMK + fINa_PKAonly * INaBase_PKA + fINa_BP * INaBase_BP
